<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header: floor navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorPrimary"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_prev_floor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_prev_floor"
            android:textColor="@android:color/white"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:enabled="false" />

        <TextView
            android:id="@+id/tv_floor_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Floor 1"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next_floor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_next_floor"
            android:textColor="@android:color/white"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:enabled="false" />
    </LinearLayout>

    <!-- Legend -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="6dp"
        android:paddingHorizontal="16dp">

        <!-- Green dot -->
        <View
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/circle_green"
            android:layout_marginEnd="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/legend_available"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="20dp" />

        <!-- Red dot -->
        <View
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/circle_red"
            android:layout_marginEnd="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/legend_occupied"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Guest note -->
    <TextView
        android:id="@+id/tv_guest_map_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/msg_guest_map_note"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingVertical="4dp"
        android:paddingHorizontal="16dp"
        android:visibility="gone" />

    <!-- Office map (custom view) -->
    <com.deskmanager.app.presentation.map.OfficeMapView
        android:id="@+id/office_map_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp" />

    <!-- Footer: desk count caption -->
    <TextView
        android:id="@+id/tv_desk_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:paddingBottom="8dp" />

</LinearLayout>
